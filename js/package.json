{
	"name": "js",
	"version": "0.0.1",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx --watch --watch-path=./src src/server.ts",
		"build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"start": "node dist/server.js",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/db/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:setup": "drizzle-kit push --force && npm run db:seed",
		"db:seed": "tsx src/seed/seed.ts",
		"db:studio": "drizzle-kit studio",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/env": "^7.0.0",
		"@fastify/helmet": "^12.0.0",
		"@fastify/rate-limit": "^10.2.2",
		"@fastify/sensible": "^6.0.0",
		"@fastify/swagger": "^9.4.0",
		"@fastify/swagger-ui": "^5.2.2",
		"@sinclair/typebox": "^0.34.6",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.43.0",
		"fastify": "^5.3.0",
		"fastify-plugin": "^5.0.1",
		"pg": "^8.13.1",
		"pino-pretty": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/node": "^22.10.2",
		"@types/pg": "^8.11.10",
		"@vitest/coverage-v8": "^3.0.0",
		"drizzle-kit": "^0.31.0",
		"lefthook": "^2.1.9",
		"tsc-alias": "^1.8.10",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
